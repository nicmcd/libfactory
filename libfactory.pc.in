prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
datarootdir = ${prefix}/share
datadir=${prefix}/share

Name: libfactory
Description: Libfactory is a library for generating abstract object factories in C++.
URL: https://github.com/nicmcd/libfactory
Version: 0.1.0
Requires: 
Libs: -L${libdir} -lfactory 
Cflags: -I${includedir}
